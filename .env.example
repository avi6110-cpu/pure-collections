# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must never be committed.

# Supabase project URL — found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon key (public) — found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (SECRET — never expose to the browser)
# Found in: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
