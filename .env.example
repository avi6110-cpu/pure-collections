# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and must never be committed.

# Supabase project URL — found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable key (safe for browser) — labeled "Publishable key" in the dashboard
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase secret key (SERVER ONLY — never expose to the browser)
# Found in: Supabase dashboard → Project Settings → API → Secret key
SUPABASE_SECRET_KEY=sb_secret_...
